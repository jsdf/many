{
  "name": "@jsdf/many",
  "version": "1.0.1",
  "description": "Git worktree pool manager for parallel development with AI tools",
  "keywords": [
    "ai",
    "git",
    "worktree",
    "claude",
    "parallel",
    "development"
  ],
  "license": "MIT",
  "author": "jsdf",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsdf/many.git"
  },
  "bin": {
    "many": "./dist-cli/cli/index.js"
  },
  "type": "module",
  "files": [
    "dist-cli/",
    "out/",
    "public/",
    "LICENSE",
    "README.md"
  ],
  "main": "dist-cli/electron/main.js",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "dev": "vite",
    "start": "npm run build && npm run build:cli && node dist-cli/cli/index.js web",
    "cli": "npm run build:cli && node dist-cli/cli/index.js",
    "check": "tsgo -p tsconfig.cli.json",
    "lint": "oxlint src/",
    "test": "vitest run",
    "electron:rebuild": "electron-rebuild -f -w @lydell/node-pty,better-sqlite3",
    "electron:dev": "npm run build && npm run build:cli && npm run electron:rebuild && electron .",
    "electron:build": "npm run build && npm run build:cli && npm run electron:rebuild && electron-builder --mac && npm run electron:rebuild:cli",
    "electron:rebuild:cli": "npm rebuild better-sqlite3 @lydell/node-pty",
    "electron:install": "npm run electron:build && ./scripts/install-mac.sh",
    "prepublishOnly": "npm run build && npm run build:cli",
    "claude-session:dev": "vite --config vite.claude-session.config.ts",
    "claude-session:build": "vite build --config vite.claude-session.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lydell/node-pty": "^1.2.0-beta.3",
    "@pierre/diffs": "^1.0.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-task-item": "^3.27.0",
    "@tiptap/extension-task-list": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "codemirror": "^6.0.2",
    "daisyui": "^5.5.19",
    "ink": "^6.7.0",
    "react": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.20.0",
    "superjson": "^2.2.2",
    "tailwindcss": "^4.2.2",
    "tiptap-markdown": "^0.9.0",
    "ws": "^8.19.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.14"
  },
  "build": {
    "appId": "com.jsdf.many",
    "productName": "Many",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/many-shodan.png",
      "target": "dir"
    },
    "files": [
      "dist-cli/**/*",
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@lydell/node-pty/**",
      "node_modules/@anthropic-ai/claude-agent-sdk/**"
    ],
    "electronLanguages": [
      "en"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260324.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "oxlint": "^1.57.0",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.2",
    "vitest": "^4.0.18"
  }
}
