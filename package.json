{
  "name": "@jsdf/many",
  "version": "1.0.1",
  "description": "Git worktree pool manager for parallel development with AI tools",
  "keywords": [
    "ai",
    "git",
    "worktree",
    "claude",
    "parallel",
    "development"
  ],
  "license": "MIT",
  "author": "jsdf",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsdf/many.git"
  },
  "bin": {
    "many": "./dist-cli/cli/index.js"
  },
  "type": "module",
  "files": [
    "dist-cli/",
    "out/",
    "public/",
    "LICENSE",
    "README.md"
  ],
  "main": "dist-cli/electron/main.js",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "dev": "vite",
    "start": "npm run build && npm run build:cli && node dist-cli/cli/index.js web",
    "cli": "npm run build:cli && node dist-cli/cli/index.js",
    "test": "vitest run",
    "electron:rebuild": "electron-rebuild -f -w @lydell/node-pty",
    "electron:dev": "npm run build && npm run build:cli && npm run electron:rebuild && electron .",
    "electron:build": "npm run build && npm run build:cli && electron-builder --mac",
    "electron:install": "npm run electron:build && ./scripts/install-mac.sh",
    "prepublishOnly": "npm run build && npm run build:cli"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@lydell/node-pty": "^1.2.0-beta.3",
    "@pierre/diffs": "^1.0.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "daisyui": "^5.5.19",
    "ink": "^6.7.0",
    "react": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.20.0",
    "superjson": "^2.2.2",
    "tailwindcss": "^4.2.2",
    "ws": "^8.19.0",
    "zod": "^4.0.14"
  },
  "build": {
    "appId": "com.jsdf.many",
    "productName": "Many",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/many-shodan.png",
      "target": "dir"
    },
    "files": [
      "dist-cli/**/*",
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": false,
    "electronLanguages": [
      "en"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3",
    "vite": "^7.1.1",
    "vitest": "^4.0.18"
  }
}
